# Copy this file to .env for local development.
# .env is intentionally ignored by git. Do not put production secrets in git.

# App runtime for direct local runs such as: drift-engine serve --reload
DRIFT_ENVIRONMENT=local
DRIFT_AUTH_REQUIRED=false
DRIFT_API_KEYS=local-dev-key
DRIFT_BASELINE_SIGNING_SECRET=local-dev-signing-secret-change-me
DRIFT_STORAGE_BACKEND=memory
DRIFT_DATABASE_URL=sqlite+aiosqlite:///./drift_engine.db
DRIFT_AUTO_CREATE_SCHEMA=true
DRIFT_SCHEDULER_ENABLED=true
DRIFT_LOG_LEVEL=INFO
DRIFT_METRICS_ENABLED=true
DRIFT_REMEDIATION_ENABLED=false
DRIFT_REMEDIATION_DRY_RUN=true

# Optional integrations. Leave empty until you intentionally connect real targets.
DRIFT_ENABLED_INTEGRATIONS=
DRIFT_KUBERNETES_NAMESPACES=
DRIFT_AWS_REGIONS=us-east-1
# DRIFT_AZURE_SUBSCRIPTION_ID=

# Docker Compose local ports and backing service credentials.
# These are development defaults only.
DRIFT_PORT=8080
POSTGRES_DB=drift
POSTGRES_USER=drift
POSTGRES_PASSWORD=drift
POSTGRES_PORT=5432
REDIS_PORT=6379
ELASTICSEARCH_PORT=9200

# Production should use DRIFT_SERVICE_ACCOUNTS instead of only DRIFT_API_KEYS.
# Example:
# DRIFT_SERVICE_ACCOUNTS=[{"id":"platform-ops","key":"replace-me","scopes":["baseline:write","scan:execute","jobs:write","audit:read"]}]
